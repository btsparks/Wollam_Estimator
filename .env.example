# WEIS Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required for query engine)
ANTHROPIC_API_KEY=your-api-key-here

# Database path (default: data/db/weis.db)
WEIS_DB_PATH=data/db/weis.db

# JCD source directory (default: data/jcd/)
WEIS_JCD_DIR=data/jcd/

# Log level (DEBUG | INFO | WARNING | ERROR)
WEIS_LOG_LEVEL=INFO
