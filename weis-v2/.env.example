# WEIS v2 Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required for AI chat)
ANTHROPIC_API_KEY=your-api-key-here

# HCSS API Credentials (required only for data sync)
HCSS_CLIENT_ID=
HCSS_CLIENT_SECRET=

# Database path (default: data/db/weis.db)
WEIS_DB_PATH=data/db/weis.db

# Dropbox Estimating folder root (for bid folder linking)
# Default: {WEIS_DROPBOX_ROOT}/Estimating
# WEIS_ESTIMATING_ROOT=C:\Users\Travis Sparks\Dropbox (Wollam)\Estimating

# Log level (DEBUG | INFO | WARNING | ERROR)
WEIS_LOG_LEVEL=INFO
