# WEIS v2 Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic API Key (required for AI chat)
ANTHROPIC_API_KEY=your-api-key-here

# HCSS API Credentials (required only for data sync)
HCSS_CLIENT_ID=
HCSS_CLIENT_SECRET=

# Database path (default: data/db/weis.db)
WEIS_DB_PATH=data/db/weis.db

# Log level (DEBUG | INFO | WARNING | ERROR)
WEIS_LOG_LEVEL=INFO
